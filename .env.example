# Local server port
PORT=8787

# Twilio credentials
TWILIO_ACCOUNT_SID=<PASTE_TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<PASTE_TWILIO_AUTH_TOKEN>
TWILIO_FROM_NUMBER=<PASTE_TWILIO_VOICE_NUMBER_E164>

# Public URLs reachable by Twilio
PUBLIC_HTTP_BASE_URL=https://<PASTE_NGROK_HOST>.ngrok-free.app
PUBLIC_WSS_BASE_URL=wss://<PASTE_NGROK_HOST>.ngrok-free.app

# OpenAI Realtime bridge
OPENAI_API_KEY=<PASTE_OPENAI_API_KEY>
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_SESSION_STYLE=legacy
OPENAI_REALTIME_USE_BETA_HEADER=false

# Optional key to protect call endpoints (used by Base44 fallback and optional browser header)
INTERNAL_API_KEY=<CREATE_LONG_RANDOM_SECRET_OR_LEAVE_BLANK>

# Set false after OpenAI Realtime is working (to avoid fake transcript lines)
MOCK_TWILIO_TRANSCRIPTS=false

